# --- UIS SIP trunk ---
# Данные из ЛК UIS: Интеграции → SIP (или у менеджера).
UIS_SIP_HOST=sip.uiscom.ru
UIS_SIP_USER=
UIS_SIP_PASSWORD=
# Номер, с которого исходящие (Caller ID в формате без +, напр. 74951234567).
UIS_CALLER_ID=

# --- OpenAI (LLM) ---
# В РФ api.openai.com напрямую не идёт. Варианты:
#   1) поднять VPN на VPS (wireguard/outline) и ходить напрямую
#   2) использовать прокси: OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
#      (ключ тот же OpenAI-совместимый от proxyapi)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Модель из экспортированного агента Retell. Актуальные альтернативы:
#   gpt-4o-mini — дешевле, быстрее
#   gpt-5.4-mini — новее (апр 2026)
OPENAI_MODEL=gpt-4.1-mini

# --- ElevenLabs (TTS) ---
# Регистрация: https://elevenlabs.io → Settings → API Keys.
# Голос: создаёшь Instant Voice Clone, копируешь Voice ID из Voices.
# Модель eleven_v3 из Retell-экспорта может быть недоступна в публичном API —
# дефолт multilingual_v2, переключи если есть доступ к v3.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Deepgram (STT, ru-RU streaming) ---
# Регистрация: https://console.deepgram.com ($200 бесплатного кредита).
DEEPGRAM_API_KEY=

# --- Bot binding ---
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=4444

LOG_LEVEL=INFO
