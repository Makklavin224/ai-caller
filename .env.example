# --- HTTP(S) прокси для внешних API ---
# OpenAI / ElevenLabs / Deepgram не отвечают напрямую с РФ IP.
# Заворачиваем их через зарубежный HTTP-прокси (CONNECT для TLS+WSS).
# Формат: http://USER:PASS@HOST:PORT  (либо без user:pass если открытый).
# SIP-трафик к UIS идёт ПОМИМО прокси (asterisk не использует HTTP_PROXY).
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1

# --- UIS SIP trunk ---
# Данные из ЛК UIS: Интеграции → SIP (или у менеджера).
UIS_SIP_HOST=pbx.uiscom.ru
UIS_SIP_USER=
UIS_SIP_PASSWORD=
# Номер, с которого исходящие (Caller ID в формате без +, напр. 74951234567).
UIS_CALLER_ID=

# --- OpenAI (LLM) ---
# base_url оставляем дефолт — трафик пойдёт через HTTPS_PROXY.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Модель из Retell-экспорта. Альтернативы:
#   gpt-4o-mini   — дешевле/быстрее
#   gpt-5.4-mini  — новее (апр 2026)
OPENAI_MODEL=gpt-4.1-mini

# --- ElevenLabs (TTS) ---
# https://elevenlabs.io → Settings → API Keys.
# Voice ID: либо Instant Voice Clone (Voices), либо из Voice Library (share link, ?voiceId=...).
# Модели TTS (по докам ElevenLabs 2026):
#   eleven_v3             — макс качество, 70+ языков (вкл. ru), высокая латенция
#   eleven_flash_v2_5     — real-time, ~75ms, RU, качество 3/5
#   eleven_turbo_v2_5     — то же, чуть медленнее
#   eleven_multilingual_v2 — баланс качества/латенции, RU
# Для живого телефонного диалога обычно flash; v3 — если важнее натуральность.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_v3

# --- Deepgram (STT, ru-RU streaming) ---
# https://console.deepgram.com ($200 бесплатного кредита).
DEEPGRAM_API_KEY=

# --- Bot binding ---
AUDIOSOCKET_HOST=0.0.0.0
AUDIOSOCKET_PORT=4444

LOG_LEVEL=INFO
