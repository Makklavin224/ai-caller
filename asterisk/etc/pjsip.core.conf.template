[global]
type=global
user_agent=AICaller-Core/1.0

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060

[ru-edge]
type=endpoint
transport=transport-udp
context=from-ru
disallow=all
allow=alaw
allow=ulaw
allow=slin16
aors=ru-edge
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[ru-edge]
type=aor
contact=sip:${RU_EDGE_IP}:5060

[ru-identify]
type=identify
endpoint=ru-edge
match=${RU_EDGE_IP}
